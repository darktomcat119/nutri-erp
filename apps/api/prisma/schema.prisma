generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTH
// ============================================
enum Role {
  ADMIN
  SUPERVISOR
  ENCARGADO
  CHOFER
}

model Usuario {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  nombre       String
  role         Role
  sucursalId   String?  @map("sucursal_id")
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sucursal           Sucursal?          @relation(fields: [sucursalId], references: [id])
  requisiciones      Requisicion[]
  recepciones        Recepcion[]
  cambiosLog         CambioCompraLog[]
  semanasCerradas    SemanaCerrada[]
  presupuestosInsGen PresupuestoIns[]   @relation("GeneradoPor")
  presupuestosInsApr PresupuestoIns[]   @relation("AprobadoPor")

  @@map("usuarios")
}

// ============================================
// BRANCHES
// ============================================
model Sucursal {
  id                      String    @id @default(uuid())
  codigo                  String    @unique
  nombre                  String
  cafeteriaId             String?   @map("cafeteria_id")
  ordereatTokenEnc        String?   @map("ordereat_token_enc")
  ordereatTokenLast4      String?   @map("ordereat_token_last4")
  ordereatTokenUpdatedAt  DateTime? @map("ordereat_token_updated_at")
  ordereatTokenUpdatedBy  String?   @map("ordereat_token_updated_by")
  activa                  Boolean   @default(true)
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  usuarios              Usuario[]
  configProductos       ConfigSucursalProducto[]
  requisiciones         Requisicion[]
  ordenesEntrega        OrdenEntrega[]
  recepciones           Recepcion[]
  inventarioPos         InventarioPos[]
  posUploads            PosUpload[]
  presupuestosSemanales PresupuestoSemanal[]
  presupuestosIns       PresupuestoIns[]
  requisicionesMos      RequisicionMos[]

  @@map("sucursales")
}

// ============================================
// SUPPLIERS
// ============================================
model Proveedor {
  id             String   @id @default(uuid())
  nombre         String   @unique
  categoria      String?
  contacto       String?
  telefono       String?
  centroCompras  String?  @map("centro_compras")
  ordenRuta      Int      @default(0) @map("orden_ruta")
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  productos        Producto[]
  insumos          Insumo[]
  ordenCompraItems OrdenCompraItem[]

  @@map("proveedores")
}

// ============================================
// CATEGORIES
// ============================================
model Categoria {
  id     String  @id @default(uuid())
  nombre String
  tipo   String  // "MOS" or "INS"
  activo Boolean @default(true)

  @@unique([nombre, tipo])
  @@map("categorias")
}

// ============================================
// PRODUCTS (MOSTRADOR)
// ============================================
model Producto {
  id            String   @id @default(uuid())
  codigo        String   @unique
  nombre        String
  nombreSistema String?  @map("nombre_sistema")
  categoria     String?
  marca         String?
  pzXDisplay    Int      @default(0) @map("pz_x_display")
  costoDisplay  Decimal  @map("costo_display") @db.Decimal(10, 2)
  costoUnitario Decimal  @map("costo_unitario") @db.Decimal(10, 2)
  proveedorId   String   @map("proveedor_id")
  ordereatId    String?  @map("ordereat_id")
  origen        String   @default("Compras")
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  proveedor           Proveedor                @relation(fields: [proveedorId], references: [id])
  configSucursales    ConfigSucursalProducto[]
  requisicionItems    RequisicionItem[]
  ordenCompraItems    OrdenCompraItem[]
  ordenEntregaItems   OrdenEntregaItem[]
  recepcionItems      RecepcionItem[]
  inventarioPos       InventarioPos[]
  requisicionMosItems RequisicionMosItem[]

  @@map("productos")
}

// ============================================
// INGREDIENTS (INSUMOS)
// ============================================
model Insumo {
  id                String   @id @default(uuid())
  codigo            String   @unique
  nombre            String
  categoria         String?
  unidad            String
  presentacion      String?
  cantidadPorDisplay Int?    @map("cantidad_por_display")
  costoUnitario     Decimal  @map("costo_unitario") @db.Decimal(10, 2)
  proveedorId       String   @map("proveedor_id")
  origen            String   @default("Compras")
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  proveedor         Proveedor         @relation(fields: [proveedorId], references: [id])
  requisicionItems  RequisicionItem[]
  ordenCompraItems  OrdenCompraItem[]
  ordenEntregaItems OrdenEntregaItem[]
  recepcionItems    RecepcionItem[]

  @@map("insumos")
}

// ============================================
// DISHES (PLATILLOS) + RECIPES
// ============================================
model Platillo {
  id        String   @id @default(uuid())
  nombre    String   @unique
  costo     Decimal  @db.Decimal(10, 2)
  precio    Decimal? @db.Decimal(10, 2)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recetaItems RecetaItem[]

  @@map("platillos")
}

model RecetaItem {
  id          String  @id @default(uuid())
  platilloId  String  @map("platillo_id")
  ingrediente String
  unidad      String
  cantidad    Decimal @db.Decimal(10, 4)
  costoUnit   Decimal @map("costo_unit") @db.Decimal(10, 4)
  costoTotal  Decimal @map("costo_total") @db.Decimal(10, 2)

  platillo Platillo @relation(fields: [platilloId], references: [id], onDelete: Cascade)

  @@map("receta_items")
}

// ============================================
// PER-BRANCH PRODUCT CONFIG (MOS maximums)
// ============================================
model ConfigSucursalProducto {
  id          String   @id @default(uuid())
  sucursalId  String   @map("sucursal_id")
  productoId  String   @map("producto_id")
  precioVenta Decimal? @map("precio_venta") @db.Decimal(10, 2)
  margen      Decimal? @db.Decimal(5, 2)
  maxSemanal  Int?     @map("max_semanal")
  quienSurte  String?  @map("quien_surte")
  activo      Boolean  @default(true)

  sucursal Sucursal @relation(fields: [sucursalId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([sucursalId, productoId])
  @@map("config_sucursal_producto")
}

// ============================================
// INS BUDGET (from sales report)
// ============================================
enum PresupuestoInsEstado {
  BORRADOR
  APROBADO
  RECHAZADO
}

model PresupuestoIns {
  id              String               @id @default(uuid())
  semana          String
  sucursalId      String               @map("sucursal_id")
  fechaEjecucion  DateTime             @map("fecha_ejecucion")
  periodoVentas   String?              @map("periodo_ventas")
  montoCalculado  Decimal              @map("monto_calculado") @db.Decimal(12, 2)
  montoAprobado   Decimal?             @map("monto_aprobado") @db.Decimal(12, 2)
  estado          PresupuestoInsEstado @default(BORRADOR)
  generadoPorId   String               @map("generado_por_id")
  aprobadoPorId   String?              @map("aprobado_por_id")
  notas           String?
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  sucursal    Sucursal @relation(fields: [sucursalId], references: [id])
  generadoPor Usuario  @relation("GeneradoPor", fields: [generadoPorId], references: [id])
  aprobadoPor Usuario? @relation("AprobadoPor", fields: [aprobadoPorId], references: [id])
  detalles    PresupuestoInsDetalle[]

  @@unique([semana, sucursalId])
  @@map("presupuestos_ins")
}

model PresupuestoInsDetalle {
  id               String @id @default(uuid())
  presupuestoInsId String @map("presupuesto_ins_id")
  productoVendido  String @map("producto_vendido")
  cantidadVendida  Int    @map("cantidad_vendida")
  costoPlatillo    Decimal @map("costo_platillo") @db.Decimal(10, 2)
  subtotal         Decimal @db.Decimal(10, 2)
  vinculado        Boolean @default(false)

  presupuestoIns PresupuestoIns @relation(fields: [presupuestoInsId], references: [id], onDelete: Cascade)

  @@map("presupuesto_ins_detalles")
}

// ============================================
// REQUISITIONS (INS — manual by Encargado)
// ============================================
enum RequisicionEstado {
  BORRADOR
  ENVIADA
  APROBADA_SUPERVISOR
  APROBADA
  RECHAZADA
}

enum AreaCompra {
  MOS
  INS
}

model Requisicion {
  id                 String            @id @default(uuid())
  semana             String
  sucursalId         String            @map("sucursal_id")
  creadoPorId        String            @map("creado_por_id")
  area               AreaCompra        @default(INS)
  estado             RequisicionEstado @default(BORRADOR)
  presupuestoInsId   String?           @map("presupuesto_ins_id")
  montoTotal         Decimal?          @map("monto_total") @db.Decimal(12, 2)
  excedePresupuesto  Boolean           @default(false) @map("excede_presupuesto")
  justificacionExceso String?          @map("justificacion_exceso")
  notasSupervisor    String?           @map("notas_supervisor")
  notasAdmin         String?           @map("notas_admin")
  notas              String?
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  sucursal  Sucursal          @relation(fields: [sucursalId], references: [id])
  creadoPor Usuario           @relation(fields: [creadoPorId], references: [id])
  items     RequisicionItem[]

  @@unique([semana, sucursalId, area])
  @@map("requisiciones")
}

model RequisicionItem {
  id                 String     @id @default(uuid())
  requisicionId      String     @map("requisicion_id")
  area               AreaCompra
  productoId         String?    @map("producto_id")
  insumoId           String?    @map("insumo_id")
  cantidadSolicitada Decimal    @map("cantidad_solicitada") @db.Decimal(10, 2)
  costoUnitario      Decimal?   @map("costo_unitario") @db.Decimal(10, 2)
  subtotal           Decimal?   @db.Decimal(10, 2)
  notas              String?

  requisicion Requisicion @relation(fields: [requisicionId], references: [id], onDelete: Cascade)
  producto    Producto?   @relation(fields: [productoId], references: [id])
  insumo      Insumo?     @relation(fields: [insumoId], references: [id])

  @@map("requisicion_items")
}

// ============================================
// MOS REQUISITION (auto-calculated)
// ============================================
enum RequisicionMosEstado {
  GENERADA
  REVISADA
  APROBADA
}

model RequisicionMos {
  id             String               @id @default(uuid())
  semana         String
  sucursalId     String               @map("sucursal_id")
  fechaInventario DateTime            @map("fecha_inventario")
  totalDisplays  Int                  @map("total_displays")
  totalDinero    Decimal              @map("total_dinero") @db.Decimal(12, 2)
  estado         RequisicionMosEstado @default(GENERADA)
  notas          String?
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  sucursal Sucursal             @relation(fields: [sucursalId], references: [id])
  items    RequisicionMosItem[]

  @@unique([semana, sucursalId])
  @@map("requisiciones_mos")
}

model RequisicionMosItem {
  id                  String  @id @default(uuid())
  requisicionMosId    String  @map("requisicion_mos_id")
  productoId          String  @map("producto_id")
  inventarioActual    Int     @map("inventario_actual")
  maximo              Int
  compraNecesaria     Int     @map("compra_necesaria")
  displaysAComprar    Int     @map("displays_a_comprar")
  costoDisplay        Decimal @map("costo_display") @db.Decimal(10, 2)
  dinero              Decimal @db.Decimal(10, 2)
  sugerenciaEncargado String? @map("sugerencia_encargado")
  cantidadFinal       Int?    @map("cantidad_final")

  requisicionMos RequisicionMos @relation(fields: [requisicionMosId], references: [id], onDelete: Cascade)
  producto       Producto       @relation(fields: [productoId], references: [id])

  @@map("requisicion_mos_items")
}

// ============================================
// PURCHASE ORDERS
// ============================================
enum OrdenCompraEstado {
  GENERADA
  APROBADA
  EN_EJECUCION
  COMPLETADA
  CANCELADA
}

model OrdenCompra {
  id            String            @id @default(uuid())
  semana        String
  folio         String            @unique
  estado        OrdenCompraEstado @default(GENERADA)
  totalEstimado Decimal?          @map("total_estimado") @db.Decimal(12, 2)
  totalReal     Decimal?          @map("total_real") @db.Decimal(12, 2)
  notas         String?
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  items    OrdenCompraItem[]
  entregas OrdenEntrega[]

  @@map("ordenes_compra")
}

model OrdenCompraItem {
  id                 String     @id @default(uuid())
  ordenCompraId      String     @map("orden_compra_id")
  area               AreaCompra
  productoId         String?    @map("producto_id")
  insumoId           String?    @map("insumo_id")
  proveedorId        String     @map("proveedor_id")
  cantidadSolicitada Decimal    @map("cantidad_solicitada") @db.Decimal(10, 2)
  cantidadComprada   Decimal?   @map("cantidad_comprada") @db.Decimal(10, 2)
  precioEstimado     Decimal    @map("precio_estimado") @db.Decimal(10, 2)
  precioReal         Decimal?   @map("precio_real") @db.Decimal(10, 2)
  comprado           Boolean    @default(false)

  ordenCompra OrdenCompra       @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  producto    Producto?          @relation(fields: [productoId], references: [id])
  insumo      Insumo?            @relation(fields: [insumoId], references: [id])
  proveedor   Proveedor          @relation(fields: [proveedorId], references: [id])
  cambiosLog  CambioCompraLog[]

  @@map("orden_compra_items")
}

// ============================================
// CHANGE LOG
// ============================================
enum TipoCambio {
  CANTIDAD
  PRECIO
  PROVEEDOR
}

model CambioCompraLog {
  id            String     @id @default(uuid())
  itemId        String     @map("item_id")
  usuarioId     String     @map("usuario_id")
  tipoCambio    TipoCambio @map("tipo_cambio")
  valorAnterior String     @map("valor_anterior")
  valorNuevo    String     @map("valor_nuevo")
  motivo        String?
  createdAt     DateTime   @default(now()) @map("created_at")

  item    OrdenCompraItem @relation(fields: [itemId], references: [id])
  usuario Usuario         @relation(fields: [usuarioId], references: [id])

  @@map("cambios_compra_log")
}

// ============================================
// DELIVERY ORDERS
// ============================================
model OrdenEntrega {
  id            String   @id @default(uuid())
  ordenCompraId String   @map("orden_compra_id")
  sucursalId    String   @map("sucursal_id")
  createdAt     DateTime @default(now()) @map("created_at")

  ordenCompra OrdenCompra        @relation(fields: [ordenCompraId], references: [id])
  sucursal    Sucursal            @relation(fields: [sucursalId], references: [id])
  items       OrdenEntregaItem[]
  recepcion   Recepcion?

  @@unique([ordenCompraId, sucursalId])
  @@map("ordenes_entrega")
}

model OrdenEntregaItem {
  id               String     @id @default(uuid())
  ordenEntregaId   String     @map("orden_entrega_id")
  area             AreaCompra
  productoId       String?    @map("producto_id")
  insumoId         String?    @map("insumo_id")
  cantidadAsignada Decimal    @map("cantidad_asignada") @db.Decimal(10, 2)

  ordenEntrega OrdenEntrega @relation(fields: [ordenEntregaId], references: [id], onDelete: Cascade)
  producto     Producto?    @relation(fields: [productoId], references: [id])
  insumo       Insumo?      @relation(fields: [insumoId], references: [id])

  @@map("orden_entrega_items")
}

// ============================================
// RECEPTION
// ============================================
model Recepcion {
  id                   String    @id @default(uuid())
  ordenEntregaId       String    @unique @map("orden_entrega_id")
  sucursalId           String    @map("sucursal_id")
  recibidoPorId        String    @map("recibido_por_id")
  firmaDigital         String?   @map("firma_digital")
  notas                String?
  pushedToOrderEatAt   DateTime? @map("pushed_to_ordereat_at")
  pushedToOrderEatBy   String?   @map("pushed_to_ordereat_by")
  createdAt            DateTime  @default(now()) @map("created_at")

  ordenEntrega OrdenEntrega    @relation(fields: [ordenEntregaId], references: [id])
  sucursal     Sucursal        @relation(fields: [sucursalId], references: [id])
  recibidoPor  Usuario         @relation(fields: [recibidoPorId], references: [id])
  items        RecepcionItem[]

  @@map("recepciones")
}

model RecepcionItem {
  id               String     @id @default(uuid())
  recepcionId      String     @map("recepcion_id")
  area             AreaCompra
  productoId       String?    @map("producto_id")
  insumoId         String?    @map("insumo_id")
  cantidadEsperada Decimal    @map("cantidad_esperada") @db.Decimal(10, 2)
  cantidadRecibida Decimal    @map("cantidad_recibida") @db.Decimal(10, 2)
  diferencia       Decimal    @map("diferencia") @db.Decimal(10, 2)
  notas            String?

  recepcion Recepcion @relation(fields: [recepcionId], references: [id], onDelete: Cascade)
  producto  Producto? @relation(fields: [productoId], references: [id])
  insumo    Insumo?   @relation(fields: [insumoId], references: [id])

  @@map("recepcion_items")
}

// ============================================
// POS INTEGRATION
// ============================================
model InventarioPos {
  id              String   @id @default(uuid())
  sucursalId      String   @map("sucursal_id")
  productoId      String   @map("producto_id")
  inventarioTotal Int      @map("inventario_total")
  reservado       Int      @default(0)
  disponible      Int
  limiteDiario    Int?     @map("limite_diario")
  fechaImport     DateTime @map("fecha_import")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@unique([sucursalId, productoId, fechaImport])
  @@map("inventario_pos")
}

model PosUpload {
  id          String   @id @default(uuid())
  sucursalId  String   @map("sucursal_id")
  semana      String
  archivoUrl  String   @map("archivo_url")
  totalItems  Int      @map("total_items")
  totalPiezas Int      @map("total_piezas")
  createdAt   DateTime @default(now()) @map("created_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@map("pos_uploads")
}

// ============================================
// WEEK CLOSING
// ============================================
model SemanaCerrada {
  id        String   @id @default(uuid())
  semana    String   @unique
  cerradoPorId String @map("cerrado_por_id")
  notas     String?
  createdAt DateTime @default(now()) @map("created_at")

  cerradoPor Usuario @relation(fields: [cerradoPorId], references: [id])

  @@map("semanas_cerradas")
}

// ============================================
// FINANCIAL
// ============================================
model PresupuestoSemanal {
  id             String   @id @default(uuid())
  semana         String
  sucursalId     String   @map("sucursal_id")
  presupuestoMos Decimal  @map("presupuesto_mos") @db.Decimal(12, 2)
  presupuestoIns Decimal  @map("presupuesto_ins") @db.Decimal(12, 2)
  gastoRealMos   Decimal? @map("gasto_real_mos") @db.Decimal(12, 2)
  gastoRealIns   Decimal? @map("gasto_real_ins") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([semana, sucursalId])
  @@map("presupuestos_semanales")
}
