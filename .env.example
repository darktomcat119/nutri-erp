# ============================================================
# Nutri ERP — environment template
# Copy to `.env` and fill in. `.env` is gitignored.
# On the VPS, store as /opt/nutri-erp/.env (chmod 600, root-owned).
# ============================================================

# Required. 32-byte key (base64). Generate ONCE per environment with:
#   openssl rand -base64 32
# Changing this invalidates every stored OrderEat token in the DB.
TOKEN_ENCRYPTION_KEY=

# Optional. OrderEat base URL. Defaults to https://api.ordereat.com.
ORDEREAT_API_URL=https://api.ordereat.com
